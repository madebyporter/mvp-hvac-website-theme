---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { posts, site } from '../../data/hvac-site-data';
---

<Layout
  title={`HVAC tips & guides | ${site.name}`}
  description="Practical heating and cooling articles for Cleveland-area homeowners—maintenance, repairs, and when to replace equipment."
  currentPath="/blog"
>
  <main>
    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto grid w-[90%] max-w-none grid-cols-12 gap-6 py-16 md:gap-8 md:py-20">
        <div class="col-span-12 lg:col-span-8">
          <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">Blog</p>
          <h1 class="mt-4 text-[clamp(2rem,4vw,3.25rem)] font-semibold leading-[1.02] tracking-[-0.04em]">
            Guides for Ohio weather and older housing stock
          </h1>
          <p class="mt-6 max-w-prose text-base leading-relaxed text-foreground-muted">
            Short reads on maintenance timing, warning signs, and how to talk to a technician—written so both search
            engines and real customers get value.
          </p>
        </div>
      </div>
    </section>

    <section class="w-full bg-background">
      <div class="mx-auto w-[90%] max-w-none divide-y divide-border py-8 md:py-12">
        {posts.map((post) => (
          <article class="py-10 md:py-12">
            <a href={`/blog/${post.slug}`} class="group grid grid-cols-12 gap-6 no-underline md:gap-8">
              <div class="col-span-12 md:col-span-8">
                <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">{post.category}</p>
                <h2 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-foreground group-hover:underline md:text-2xl">
                  {post.title}
                </h2>
                <p class="mt-3 text-sm leading-relaxed text-foreground-muted">{post.excerpt}</p>
              </div>
              <div class="col-span-12 text-sm text-foreground-muted md:col-span-4 md:text-right">{post.date}</div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

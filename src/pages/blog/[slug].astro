---
export const prerender = true;

import Button from '../../components/Button.astro';
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/hvac-site-data';

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;

const bodies: Record<string, string[]> = {
  'when-ac-repair-vs-replace': [
    'If your central air is more than twelve to fifteen years old, repair bills can approach a meaningful fraction of replacement cost—especially if the system still uses older refrigerant or the outdoor coil is corroding.',
    'A good rule of thumb: multiply the quoted repair by the equipment age. If the number creeps past a few thousand dollars, ask for load calculations and efficiency comparisons on a new system, not just a patch.',
    'We document pressures, temperatures, and amp draws so you can see why we recommend repair versus swap. Rebates and financing change seasonally; we will note what applies when we quote.',
  ],
  'spring-hvac-checklist-cleveland': [
    'Before you switch the thermostat to cool, clear a two-foot zone around the outdoor unit and glance at the disconnect for wasp nests—lake humidity makes Cleveland coils work harder than inland climates.',
    'Inside, swap the filter to the size printed on the existing frame (never guess), and if you have a humidifier bypass, close the summer damper if your model uses one.',
    'Schedule a tune-up in April or early May: capacitors and contactors fail under the first heat wave, and a planned visit beats a 90-degree weekend waitlist.',
  ],
  'furnace-airflow-warning-signs': [
    'Long run times with a lukewarm house often trace to airflow: dirty filters, stuck dampers, or a blower motor working against a blocked return.',
    'Whistling at registers, doors that slam when the fan starts, or cold spots on upper floors can mean duct leakage or undersized returns—common in pre-1980 builds around the Heights.',
    'If you smell electrical heat or see the high-limit trip repeatedly, shut the system off and call—those are safety issues, not “wait until Monday” items.',
  ],
};

const paragraphs = bodies[post.slug] ?? [
  'This article is part of the site’s content template. Replace the body with copy from EmDash or your CMS when you connect collections.',
];
---

<Layout title={`${post.title} | Blog`} description={post.excerpt} currentPath="/blog">
  <main>
    <article class="w-full border-b border-border bg-background">
      <header class="mx-auto grid max-w-none grid-cols-12 gap-6 p-8 md:gap-8">
        <div class="col-span-12 lg:col-span-9">
          <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">
            {post.category} · {post.date}
          </p>
          <h1 class="mt-4 text-[clamp(2rem,4vw,3.25rem)] font-semibold leading-[1.02] tracking-[-0.04em]">
            {post.title}
          </h1>
          <p class="mt-6 max-w-prose text-base leading-relaxed text-foreground-muted">{post.excerpt}</p>
        </div>
      </header>

      <div class="mx-auto grid max-w-none grid-cols-12 gap-10 p-8 md:gap-12">
        <div class="col-span-12 max-w-prose lg:col-span-8">
          <div class="space-y-6 text-[15px] leading-7 text-foreground-muted">
            {paragraphs.map((p) => <p>{p}</p>)}
          </div>
        </div>
        <aside class="col-span-12 lg:col-span-4">
          <div class="rounded-2xl border border-border bg-surface p-4 md:sticky md:top-28">
            <p class="text-sm font-medium text-foreground">Need help with this?</p>
            <p class="mt-2 text-sm leading-relaxed text-foreground-muted">
              Describe what you are seeing—we will route it to the right technician.
            </p>
            <Button type="button" class="mt-4 w-full" data-drawer-open>
              Open contact
            </Button>
          </div>
        </aside>
      </div>
    </article>
  </main>
</Layout>

---
import "../styles/global.css";
import Button from "../components/Button.astro";
import ContactDrawer from "../components/ContactDrawer.astro";
import { nav, site } from "../data/hvac-site-data";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = "North Coast Heating & Cooling | Cleveland HVAC",
  description = "Heating, air conditioning, and indoor comfort for homes and businesses across Greater Cleveland.",
  currentPath = "/",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="m-0 min-h-screen bg-background font-sans text-foreground antialiased"
  >
    <div class="flex min-h-screen flex-col">
      <header class="fixed top-8 z-40 w-full">
        <div class="mx-auto flex px-8 max-w-none">
          <nav
            class="inline-flex items-stretch gap-4 rounded-sm bg-black p-2 px-4 pr-2 backdrop-blur-sm"
            aria-label="Primary"
          >
            <a
              href="/"
              class="inline-flex h-11 w-28 items-center justify-center rounded-xs text-neutral-100 no-underline font-bold"
            >
              {site.logoInitials}
            </a>
            <div class="flex items-center gap-1 sm:gap-1.5">
              {
                nav.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      "inline-flex h-full items-center rounded-xs px-2 text-sm text-neutral-300 no-underline transition-colors",
                      currentPath === item.href
                        ? "font-bold text-neutral-100"
                        : "hover:text-neutral-100",
                    ]}
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
            <Button type="button" data-drawer-open>Contact</Button>
          </nav>
        </div>
      </header>

      <slot />

      <footer class="mt-auto w-full border-t border-border bg-background">
        <div class="mx-auto grid max-w-none grid-cols-12 gap-6 p-8 md:gap-8">
          <div class="col-span-12 md:col-span-7">
            <p
              class="text-xs font-medium uppercase tracking-[0.14em] text-foreground-muted"
            >
              {site.name}
            </p>
            <p
              class="mt-2 max-w-prose text-sm leading-relaxed text-foreground-muted"
            >
              Licensed HVAC for Greater Cleveland—repairs, replacements,
              maintenance, and light commercial service.
            </p>
          </div>
          <div
            class="col-span-12 flex flex-col gap-2 text-sm text-foreground-muted md:col-span-3"
          >
            <a
              href={`tel:${site.phoneTel}`}
              class="text-foreground no-underline hover:underline"
              >{site.phoneDisplay}</a
            >
            <span>{site.city}</span>
          </div>
          <div
            class="col-span-12 md:col-span-2 md:flex md:items-start md:justify-end"
          >
            <Button
              type="button"
              class="!h-fit w-full min-h-11 md:w-auto"
              data-drawer-open
            >
              Contact
            </Button>
          </div>
          <div class="col-span-12 border-t border-border p-4 text-xs text-foreground-muted">
            Serving {site.serviceArea.slice(0, 6).join(" · ")}
            {site.serviceArea.length > 6 ? " · …" : ""}
          </div>
        </div>
      </footer>
    </div>

    <ContactDrawer />
  </body>
</html>

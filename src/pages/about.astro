---
import Layout from '../layouts/Layout.astro';
import SiteFrame from '../components/SiteFrame.astro';
---

<Layout title="HVAC Theme / About" description="About page wireframe.">
  <SiteFrame title="HVAC Theme / About" description="About page wireframe." currentPath="/about">
    <main class="py-6 md:py-8">
      <div class="section-shell grid gap-4 md:gap-6">
        <section class="grid gap-4 md:grid-cols-[1.1fr_.9fr]">
          <div class="module-card layer-1 rounded-[28px] p-5 md:p-8">
            <div class="eyebrow mb-3">About</div>
            <h1 class="display-wire max-w-[12ch] text-[clamp(2.5rem,5vw,5rem)]">A better local-service brand frame.</h1>
            <p class="copy-wire mt-4">This page should feel like confidence and operational clarity, not a wall of stock-photo trust claims. The design goal is calm credibility.</p>
          </div>
          <div class="module-card layer-2 rounded-[28px] p-5 md:p-8">
            <div class="module-label mb-3">Company facts</div>
            <div class="grid gap-3">
              <div class="module-card layer-1 rounded-2xl p-4">Years in business</div>
              <div class="module-card layer-1 rounded-2xl p-4">Licensed + insured</div>
              <div class="module-card layer-1 rounded-2xl p-4">Manufacturer relationships</div>
            </div>
          </div>
        </section>

        <section class="grid-modules two-up">
          <div class="module-card layer-1 rounded-[24px] p-5 md:p-6">
            <div class="module-label mb-3">Story module</div>
            <p class="copy-wire">Keep this practical: how the company works, what it values, and why customers trust it. No bloated brand monologue.</p>
          </div>
          <div class="module-card layer-1 rounded-[24px] p-5 md:p-6">
            <div class="module-label mb-3">Team / process module</div>
            <p class="copy-wire">A clean, modular way to show technicians, office process, dispatch reliability, and service standards.</p>
          </div>
        </section>
      </div>
    </main>
  </SiteFrame>
</Layout>

---
export const prerender = false;

import { PortableText } from 'emdash/ui';
import Button from '../../components/Button.astro';
import SubpageHero from '../../components/SubpageHero.astro';
import Layout from '../../layouts/Layout.astro';
import { heroSpecialSlides } from '../../data/hvac-site-data';
import { loadBlogPost } from '../../lib/emdash/loadBlogPost';

const slug = Astro.params.slug;
if (!slug) {
  return new Response(null, { status: 404 });
}

const post = await loadBlogPost(slug, {
  imageSrc: heroSpecialSlides[0].imageSrc,
  imageAlt: heroSpecialSlides[0].imageAlt,
});
if (!post) {
  return new Response(null, { status: 404 });
}

const eyebrow = [post.category, post.date].filter(Boolean).join(' · ') || 'Blog';
---

<Layout title={`${post.title} | Blog`} description={post.excerpt} currentPath="/blog">
  <main>
    <article class="w-full">
      <SubpageHero
        eyebrow={eyebrow}
        title={post.title}
        description={post.excerpt}
        imageSrc={post.imageSrc}
        imageAlt={post.imageAlt}
      />

      <div class="mx-auto grid max-w-none grid-cols-12 gap-10 border-b border-border bg-background p-16 md:gap-12">
        <div class="col-span-12 max-w-prose lg:col-span-8">
          <div
            class="blog-pt space-y-6 text-[15px] leading-7 text-foreground-muted [&_a]:text-foreground [&_a]:underline [&_li]:my-1 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6"
          >
            <PortableText value={post.content} />
          </div>
        </div>
        <aside class="col-span-12 lg:col-span-4">
          <div class="md:sticky md:top-28">
            <div
              class="flex flex-col gap-2 rounded-sm border border-background bg-white p-4 text-foreground xl:p-8"
            >
              <div class="flex flex-col gap-0">
                <p class="text-xs font-medium uppercase tracking-[0.14em] text-foreground-muted">
                  Contact
                </p>
                <h3 class="text-lg font-semibold tracking-[-0.03em]">Need help with this?</h3>
              </div>
              <p class="text-sm leading-relaxed text-foreground-muted">
                Describe what you are seeing—we will route it to the right technician.
              </p>
              <Button type="button" class="mt-4 w-full" data-drawer-open>
                Contact Us
              </Button>
            </div>
          </div>
        </aside>
      </div>
    </article>
  </main>
</Layout>

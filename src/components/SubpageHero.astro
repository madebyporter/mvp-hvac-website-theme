---
/**
 * Short two-column black hero (home hero without slideshow).
 * Top padding clears the fixed header so the bar can sit over the black band.
 */
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  imageSrc: string;
  imageAlt: string;
}

const { eyebrow, title, description, imageSrc, imageAlt } = Astro.props;
---

<section
  class="w-full border-b border-white/10 bg-zinc-950 text-white"
  aria-label="Page introduction"
>
  <div class="max-w-none p-16 pt-32">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:items-end md:gap-8">
      <div
        class="order-2 flex min-h-44 flex-col justify-end gap-4 md:order-1 md:col-span-5 md:min-h-52"
      >
        <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-white/55">
          {eyebrow}
        </p>
        <h1
          class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-white"
        >
          {title}
        </h1>
        {
          description ? (
            <p class="max-w-prose text-sm leading-relaxed text-white/75 md:max-w-md">
              {description}
            </p>
          ) : null
        }
        <slot name="actions" />
      </div>
      <div
        class="relative order-1 min-h-44 h-full overflow-hidden rounded-sm md:order-2 md:col-span-7 lg:rounded-xs"
      >
        <img
          src={imageSrc}
          alt={imageAlt}
          width={1600}
          height={1067}
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>

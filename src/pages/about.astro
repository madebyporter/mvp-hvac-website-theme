---
import Layout from '../layouts/Layout.astro';
import SiteFrame from '../components/SiteFrame.astro';
---

<Layout title="HVAC Theme / About" description="About page wireframe.">
  <SiteFrame title="HVAC Theme / About" description="About page wireframe." currentPath="/about">
    <main class="py-6 md:py-8">
      <div class="section-shell grid gap-4 md:gap-6">
        <section class="grid gap-4 md:grid-cols-[1.1fr_.9fr]">
          <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[28px] p-5 md:p-8">
            <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">About</div>
            <h1 class="text-[clamp(2.75rem,6vw,6.5rem)] leading-[0.94] tracking-[-0.055em] font-semibold max-w-[12ch] text-[clamp(2.5rem,5vw,5rem)]">A better local-service brand frame.</h1>
            <p class="max-w-[68ch] text-base leading-[1.55] text-[#5b5b5b] mt-4">This page should feel like confidence and operational clarity, not a wall of stock-photo trust claims. The design goal is calm credibility.</p>
          </div>
          <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-[28px] p-5 md:p-8">
            <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Company facts</div>
            <div class="grid gap-3">
              <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-2xl p-4">Years in business</div>
              <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-2xl p-4">Licensed + insured</div>
              <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-2xl p-4">Manufacturer relationships</div>
            </div>
          </div>
        </section>

        <section class="grid gap-4 md:grid-cols-2">
          <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[24px] p-5 md:p-6">
            <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Story module</div>
            <p class="max-w-[68ch] text-base leading-[1.55] text-[#5b5b5b]">Keep this practical: how the company works, what it values, and why customers trust it. No bloated brand monologue.</p>
          </div>
          <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[24px] p-5 md:p-6">
            <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Team / process module</div>
            <p class="max-w-[68ch] text-base leading-[1.55] text-[#5b5b5b]">A clean, modular way to show technicians, office process, dispatch reliability, and service standards.</p>
          </div>
        </section>
      </div>
    </main>
  </SiteFrame>
</Layout>

---
const { compact = false } = Astro.props;
---

<div id="contact-drawer" class="drawer-shell" aria-hidden="true">
  <div class="drawer-backdrop" data-drawer-close></div>
  <div class="drawer-panel module-card layer-1">
    <div class="drawer-handle"></div>
    <div class="flex items-start justify-between gap-4">
      <div class="grid gap-2">
        <div class="eyebrow">Contact drawer</div>
        <h2 class="heading-wire text-[clamp(1.5rem,2vw,2.25rem)]">Start with chat. Switch to form if you want.</h2>
        <p class="copy-wire max-w-[60ch]">Default the contact experience to an agentic intake flow, but keep a classic quote request form one tap away for users who just want the standard route.</p>
      </div>
      <button class="close-button" type="button" data-drawer-close aria-label="Close contact drawer">×</button>
    </div>

    <div class="mt-6 inline-flex rounded-full border border-[var(--border)] bg-[var(--layer-2)] p-1 text-sm">
      <button class="toggle-pill is-active" type="button" data-tab-target="chat">Agentic chat</button>
      <button class="toggle-pill" type="button" data-tab-target="form">Classic form</button>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-[1.15fr_.85fr]">
      <section class="tab-panel is-active module-card layer-2 rounded-[20px] p-4 md:p-5" data-tab-panel="chat">
        <div class="module-label mb-4">Chat-first intake</div>
        <div class="grid gap-3">
          <div class="chat-bubble chat-bubble--system">What do you need help with today?</div>
          <div class="chat-bubble chat-bubble--user">AC not cooling well upstairs.</div>
          <div class="chat-bubble chat-bubble--system">Got it. Want repair, tune-up, or quote options?</div>
          <div class="grid gap-2 md:grid-cols-3">
            <div class="module-card layer-1 rounded-2xl px-4 py-3 text-sm">Repair</div>
            <div class="module-card layer-1 rounded-2xl px-4 py-3 text-sm">Tune-up</div>
            <div class="module-card layer-1 rounded-2xl px-4 py-3 text-sm">Replacement quote</div>
          </div>
        </div>
      </section>

      <section class="tab-panel module-card layer-2 rounded-[20px] p-4 md:p-5" data-tab-panel="form">
        <div class="module-label mb-4">Classic quote request</div>
        <div class="grid gap-3">
          <div class="form-field">Name</div>
          <div class="form-field">Email + phone</div>
          <div class="form-field">Zip code / city</div>
          <div class="form-field">Service needed</div>
          <div class="form-field h-24 items-start pt-4">Tell us what’s going on</div>
          <button class="button-wire w-full justify-center">Request quote</button>
        </div>
      </section>
    </div>
  </div>
</div>

<script>
  const root = document;
  const drawer = root.querySelector('#contact-drawer');
  const openers = root.querySelectorAll('[data-drawer-open]');
  const closers = root.querySelectorAll('[data-drawer-close]');
  const tabButtons = root.querySelectorAll('[data-tab-target]');
  const tabPanels = root.querySelectorAll('[data-tab-panel]');

  const setOpen = (open) => {
    if (!drawer) return;
    drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
    document.documentElement.classList.toggle('drawer-open', open);
  };

  openers.forEach((button) => button.addEventListener('click', () => setOpen(true)));
  closers.forEach((button) => button.addEventListener('click', () => setOpen(false)));

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const target = button.getAttribute('data-tab-target');
      tabButtons.forEach((item) => item.classList.toggle('is-active', item === button));
      tabPanels.forEach((panel) => panel.classList.toggle('is-active', panel.getAttribute('data-tab-panel') === target));
    });
  });
</script>

---
export const prerender = false;

import Button from '../components/Button.astro';
import BlogTeaserSection from '../components/BlogTeaserSection.astro';
import BucketGrid from '../components/BucketGrid.astro';
import Layout from '../layouts/Layout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import Slideshow from '../components/Slideshow.astro';
import {
  heroSpecialSlides,
  homeLanding,
  posts as fallbackPosts,
  services,
  site,
} from '../data/hvac-site-data';
import { loadHomePostTeasers } from '../lib/emdash/loadHomePosts';
import { mapTileData } from '../lib/emdash/mapTile';
import type { ContentTileProps } from '../lib/emdash/mapTile';
import type { HomePostTeaser } from '../lib/emdash/loadHomePosts';
import type { TitleHeadingLevel } from '../lib/emdash/loadSlideshow';

const slides = heroSpecialSlides.map((s) => ({
  segment: s.segment,
  title: s.title,
  blurb: s.blurb,
  ctaLabel: s.ctaLabel,
  ctaHref: s.ctaHref,
  imageSrc: s.imageSrc,
  imageAlt: s.imageAlt,
}));

const hl = homeLanding.slideshowTitleHeadingLevel;
const titleHeadingLevel: TitleHeadingLevel =
  hl === 'h2' || hl === 'h3' ? hl : 'h1';

const tiles: ContentTileProps[] = services.map((s) =>
  mapTileData({
    eyebrow: homeLanding.tileCardEyebrow,
    title: s.name,
    summary: s.summary,
    link_href: `/services#${s.slug}`,
    image_src: s.imageSrc,
    image_alt: s.imageAlt,
    sort_order: 0,
    placement: 'both',
  }),
);

let postTeasers: HomePostTeaser[] = await loadHomePostTeasers(2);
if (postTeasers.length === 0) {
  postTeasers = fallbackPosts.slice(0, 2).map((p) => ({
    slug: p.slug,
    title: p.title,
    excerpt: p.excerpt,
    category: p.category,
  }));
}
---

<Layout
  title={`${site.name} | Cleveland HVAC repair, install & maintenance`}
  description={`${site.tagline} Call ${site.phoneDisplay} for service, tune-ups, and emergency help.`}
  currentPath="/"
>
  <main class="bg-background">
    <Slideshow
      slides={slides}
      titleHeadingLevel={titleHeadingLevel}
      rootId="slideshow"
      ariaLabel="Featured HVAC offers and service highlights"
    />

    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto grid p-16 max-w-none grid-cols-12 gap-8">
        <SectionIntro
          eyebrow={homeLanding.tilesSectionEyebrow}
          heading={homeLanding.tilesSectionHeading}
        >
          <div slot="actions" class="flex justify-start md:justify-end">
            <Button href={homeLanding.tilesCtaHref} class="w-fit">
              {homeLanding.tilesCtaLabel}
            </Button>
          </div>
        </SectionIntro>
        <BucketGrid tiles={tiles} />
      </div>
    </section>

    <BlogTeaserSection
      eyebrow={homeLanding.blogTeaserEyebrow}
      heading={homeLanding.blogTeaserHeading}
      posts={postTeasers}
      viewAllLabel={homeLanding.blogViewAllLabel}
    />
  </main>
</Layout>

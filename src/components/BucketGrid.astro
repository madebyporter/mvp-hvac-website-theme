---
import type { ContentTileProps } from '../lib/emdash/mapTile';

interface Props {
  tiles: ContentTileProps[];
}

const { tiles } = Astro.props;
---

<div class="col-span-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
  {
    tiles.map((tile) => (
      <a
        href={tile.linkHref}
        class="flex flex-col rounded-2xl border border-border bg-surface p-5 no-underline text-current shadow-[0_1px_0_rgba(0,0,0,0.03)] transition-colors hover:bg-surface-muted md:p-6"
      >
        <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">
          {tile.eyebrow}
        </p>
        <h3 class="mt-3 text-lg font-semibold tracking-[-0.03em]">{tile.title}</h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-foreground-muted">{tile.summary}</p>
      </a>
    ))
  }
</div>

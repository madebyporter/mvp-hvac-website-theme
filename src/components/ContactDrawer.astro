---
import Button from "./Button.astro";
---

<div
  id="contact-drawer"
  class="group fixed inset-0 z-50 transition-opacity duration-300 aria-[hidden=true]:pointer-events-none aria-[hidden=true]:opacity-0 aria-[hidden=false]:opacity-100"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-drawer-title"
>
  <div class="absolute inset-0 bg-black/40 backdrop-blur-[2px]" data-drawer-close tabindex="-1"></div>

  <div
    class="fixed bottom-4 left-4 top-4 flex w-[min(100%,420px)] max-w-[calc(100vw-2rem)] flex-col overflow-hidden rounded-3xl bg-zinc-950 shadow-2xl shadow-black/50 ring-1 ring-white/10 transition-transform duration-300 ease-out translate-x-[-calc(100%+24px)] group-aria-[hidden=false]:translate-x-0"
  >
    <div class="flex shrink-0 items-start justify-between gap-4 px-6 pb-2 pt-6">
      <div
        class="flex gap-6 text-sm font-medium"
        role="tablist"
        aria-label="Contact method"
      >
        <Button
          variant="tab"
          type="button"
          role="tab"
          id="tab-chat"
          aria-selected="true"
          aria-controls="panel-chat"
          data-tab-target="chat"
        >
          Chat
        </Button>
        <Button
          variant="tab"
          type="button"
          role="tab"
          id="tab-form"
          aria-selected="false"
          aria-controls="panel-form"
          data-tab-target="form"
        >
          Contact
        </Button>
      </div>
      <Button variant="icon" type="button" data-drawer-close aria-label="Close">
        ×
      </Button>
    </div>

    <div class="flex min-h-0 flex-1 flex-col px-6 pb-6 pt-2">
      <section
        id="panel-chat"
        role="tabpanel"
        aria-labelledby="tab-chat"
        class="flex min-h-0 flex-1 flex-col"
        data-tab-panel="chat"
      >
        <div class="min-h-0 flex-1 overflow-y-auto overscroll-contain">
          <p class="text-xs font-medium text-zinc-500">Assistant</p>
          <h2 id="contact-drawer-title" class="sr-only">Chat with us</h2>
          <p class="mt-3 text-[15px] leading-relaxed text-white">
            Hey — I'm here to help with heating and cooling in Greater Cleveland. What do you need today?
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <Button
              type="button"
              class="min-w-0 max-w-full justify-start text-left text-sm"
            >
              Emergency repair
            </Button>
            <Button
              type="button"
              class="min-w-0 max-w-full justify-start text-left text-sm"
            >
              Schedule a quote
            </Button>
            <Button
              type="button"
              class="min-w-0 max-w-full justify-start text-left text-sm"
            >
              Maintenance plan
            </Button>
            <Button
              type="button"
              class="min-w-0 max-w-full justify-start text-left text-sm"
            >
              Something else
            </Button>
          </div>
          <p class="mt-6 text-xs leading-relaxed text-zinc-500">
            Connect your AI agent to this drawer when ready — wire the composer below to your SDK or embed.
          </p>
        </div>
        <div class="shrink-0 border-t border-white/10 pt-5">
          <div class="flex items-center gap-3 rounded-full border border-white/20 bg-white/5 px-4 py-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/10 text-[10px] text-zinc-400" aria-hidden="true">NC</span>
            <input
              type="text"
              class="min-h-0 flex-1 border-none bg-transparent text-sm text-white placeholder:text-zinc-500 focus:outline-none focus:ring-0"
              placeholder="Ask me anything…"
              autocomplete="off"
              aria-label="Message to assistant"
            />
            <Button variant="icon" type="button" aria-label="Send">
              <span class="block h-1.5 w-1.5 rounded-full bg-inverse-foreground" aria-hidden="true"></span>
            </Button>
          </div>
        </div>
      </section>

      <section
        id="panel-form"
        role="tabpanel"
        aria-labelledby="tab-form"
        hidden
        class="flex min-h-0 flex-1 flex-col overflow-y-auto"
        data-tab-panel="form"
      >
        <h2 class="text-base font-semibold leading-snug text-white">
          Request service or a callback. Prefer email? We read everything during business hours.
        </h2>
        <form class="mt-6 grid gap-4" method="post" action="#" data-contact-form>
          <label class="grid gap-1.5 text-xs font-medium text-zinc-500">
            Name
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-12 w-full rounded-2xl border border-white/25 bg-transparent px-4 text-sm text-white placeholder:text-zinc-500 focus:border-white/50 focus:outline-none focus:ring-1 focus:ring-white/30"
              placeholder="Your name"
            />
          </label>
          <label class="grid gap-1.5 text-xs font-medium text-zinc-500">
            Email
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-12 w-full rounded-2xl border border-white/25 bg-transparent px-4 text-sm text-white placeholder:text-zinc-500 focus:border-white/50 focus:outline-none focus:ring-1 focus:ring-white/30"
              placeholder="you@example.com"
            />
          </label>
          <label class="grid gap-1.5 text-xs font-medium text-zinc-500">
            Phone
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              class="min-h-12 w-full rounded-2xl border border-white/25 bg-transparent px-4 text-sm text-white placeholder:text-zinc-500 focus:border-white/50 focus:outline-none focus:ring-1 focus:ring-white/30"
              placeholder="(216) …"
            />
          </label>
          <label class="grid gap-1.5 text-xs font-medium text-zinc-500">
            Zip or city
            <input
              type="text"
              name="location"
              autocomplete="address-level2"
              class="min-h-12 w-full rounded-2xl border border-white/25 bg-transparent px-4 text-sm text-white placeholder:text-zinc-500 focus:border-white/50 focus:outline-none focus:ring-1 focus:ring-white/30"
              placeholder="44102 or Lakewood"
            />
          </label>
          <label class="grid gap-1.5 text-xs font-medium text-zinc-500">
            What do you need?
            <select
              name="service"
              class="min-h-12 w-full rounded-2xl border border-white/25 bg-zinc-950 px-4 text-sm text-white focus:border-white/50 focus:outline-none focus:ring-1 focus:ring-white/30"
            >
              <option value="">Select…</option>
              <option value="ac">Air conditioning</option>
              <option value="heat">Heating</option>
              <option value="maintenance">Maintenance / tune-up</option>
              <option value="commercial">Commercial</option>
              <option value="other">Other</option>
            </select>
          </label>
          <label class="grid gap-1.5 text-xs font-medium text-zinc-500">
            Details
            <textarea
              name="message"
              rows="3"
              class="w-full resize-y rounded-2xl border border-white/25 bg-transparent px-4 py-3 text-sm text-white placeholder:text-zinc-500 focus:border-white/50 focus:outline-none focus:ring-1 focus:ring-white/30"
              placeholder="Equipment age, symptoms, best time to call…"
            ></textarea>
          </label>
          <Button type="submit" class="w-full">
            Send message
          </Button>
          <p class="text-xs leading-relaxed text-zinc-500">
            Wire <code class="rounded bg-white/10 px-1 py-0.5 font-mono text-[11px] text-zinc-300">action</code> to your
            endpoint when you deploy.
          </p>
        </form>
      </section>
    </div>
  </div>
</div>

<script is:inline src="/contact-drawer.js"></script>

---
import ContactDrawer from './ContactDrawer.astro';
import { nav, site } from '../data/site';

const { title, description, currentPath = '/' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header section-shell">
        <div class="flex justify-center">
          <nav class="inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--layer-1)] p-1.5 shadow-[var(--shadow-soft)]">
            <a href="/" class="inline-flex min-h-10 items-center justify-center rounded-full border border-[var(--border)] bg-[var(--layer-2)] px-4 text-sm font-medium text-[var(--ink)] no-underline">
              NW
            </a>

            <div class="h-8 w-px bg-[var(--border)]"></div>

            <div class="flex items-center gap-1 sm:gap-1.5">
              {nav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'inline-flex min-h-10 items-center rounded-full px-3.5 text-sm text-[var(--ink)] no-underline transition-colors',
                    currentPath === item.href ? 'border border-[var(--border)] bg-[var(--layer-2)]' : 'border border-transparent bg-transparent',
                  ]}
                >
                  {item.label}
                </a>
              ))}

              <div class="ml-1 h-8 w-px bg-[var(--border)]"></div>

              <button type="button" class="button-wire ml-1" data-drawer-open>Contact us</button>
            </div>
          </nav>
        </div>
      </header>

      <slot />

      <footer class="section-shell pb-6 md:pb-8">
        <div class="module-card layer-1 rounded-[24px] p-5 md:p-6">
          <div class="grid gap-4 md:grid-cols-[1fr_auto_auto] md:items-end">
            <div class="grid gap-2">
              <div class="module-label">Footer module</div>
              <div class="text-xl font-medium tracking-[-0.03em]">Minimal HVAC website theme.</div>
              <p class="copy-wire">Built to be reskinned per brand without changing the core layout logic.</p>
            </div>
            <div class="text-sm text-neutral-700">Service area: {site.serviceArea.join(' • ')}</div>
            <button type="button" class="button-wire" data-drawer-open>Open contact drawer</button>
          </div>
        </div>
      </footer>
    </div>

    <ContactDrawer />
  </body>
</html>

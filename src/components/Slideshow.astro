---
import Button from './Button.astro';
import type { SlideshowSlideProps } from '../lib/emdash/mapSlide';
import type { TitleHeadingLevel } from '../lib/emdash/loadSlideshow';

interface Props {
  slides: SlideshowSlideProps[];
  titleHeadingLevel: TitleHeadingLevel;
  rootId?: string;
  ariaLabel?: string;
}

const {
  slides,
  titleHeadingLevel,
  rootId = 'slideshow',
  ariaLabel = 'Featured slides',
} = Astro.props;
---

<section
  id={rootId}
  class="w-full border-b border-border bg-background"
  aria-roledescription="carousel"
  aria-label={ariaLabel}
>
  <div class="mx-auto p-2 max-w-none">
    <div
      class="grid grid-cols-1 overflow-hidden rounded-2xl border border-border bg-zinc-950 ring-1 ring-black/5 md:grid-cols-12 md:rounded-none md:border-0 md:ring-0 lg:rounded-sm"
    >
      <div
        class="relative flex min-h-[min(58vh,560px)] flex-col md:order-1 md:col-span-5 md:min-h-[min(72vh,640px)]"
      >
        <div class="relative flex min-h-0 flex-1 flex-col">
          {
            slides.map((slide, i) => (
              <div
                data-slideshow-panel={i}
                hidden={i !== 0}
                aria-hidden={i === 0 ? 'false' : 'true'}
                class="flex flex-1 flex-col justify-end p-16"
              >
                <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-white/55">
                  {slide.segment}
                </p>
                {titleHeadingLevel === 'h1' && (
                  <h1 class="mt-3 text-[clamp(1.5rem,3.5vw,2.75rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-white text-pretty">
                    {slide.title}
                  </h1>
                )}
                {titleHeadingLevel === 'h2' && (
                  <h2 class="mt-3 text-[clamp(1.5rem,3.5vw,2.75rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-white text-pretty">
                    {slide.title}
                  </h2>
                )}
                {titleHeadingLevel === 'h3' && (
                  <h3 class="mt-3 text-[clamp(1.5rem,3.5vw,2.75rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-white text-pretty">
                    {slide.title}
                  </h3>
                )}
                <p class="mt-4 max-w-md text-sm leading-relaxed text-white/75">{slide.blurb}</p>
                <a
                  href={slide.ctaHref}
                  class="mt-6 inline-flex w-fit items-center gap-1 text-sm font-medium text-white underline decoration-white/35 underline-offset-4 transition-colors hover:decoration-white"
                >
                  {slide.ctaLabel}
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            ))
          }
        </div>
        <div class="flex shrink-0 items-center justify-between p-8">
          <div class="flex items-center gap-2" role="group" aria-label="Slide indicators">
            {
              slides.map((_, i) => (
                <Button
                  variant="dash"
                  type="button"
                  data-slideshow-dot={i}
                  aria-label={`Slide ${i + 1} of ${slides.length}`}
                  aria-current={i === 0 ? 'true' : undefined}
                  class:list={[i === 0 ? 'bg-white' : 'bg-white/30']}
                />
              ))
            }
          </div>
          <div class="flex gap-1">
            <Button variant="icon" type="button" data-slideshow-prev class="text-lg" aria-label="Previous slide">
              ‹
            </Button>
            <Button variant="icon" type="button" data-slideshow-next class="text-lg" aria-label="Next slide">
              ›
            </Button>
          </div>
        </div>
      </div>
      <div
        class="relative order-first min-h-[min(36vh,280px)] md:order-2 md:col-span-7 md:min-h-[min(72vh,640px)]"
      >
        {
          slides.map((slide, i) => (
            <img
              data-slideshow-img={i}
              src={slide.imageSrc}
              alt={slide.imageAlt}
              width={1600}
              height={1067}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              aria-hidden={i === 0 ? 'false' : 'true'}
              class:list={[
                'absolute inset-0 h-full w-full object-cover transition-opacity duration-500 motion-reduce:transition-none',
                i === 0 ? 'opacity-100' : 'opacity-0',
              ]}
            />
          ))
        }
      </div>
    </div>
  </div>
  <script is:inline src="/slideshow.js"></script>
</section>

---
import type { ContentTileProps } from '../lib/emdash/mapTile';

interface Props {
  tiles: ContentTileProps[];
}

const { tiles } = Astro.props;
---

<div class="col-span-12 grid gap-4 sm:grid-cols-2 lg:gap-5 xl:grid-cols-4">
  {
    tiles.map((tile) => (
      <a href={tile.linkHref} class="flex flex-col gap-2 justify-start rounded-sm border border-background bg-white no-underline text-current transition-colors hover:bg-white">
        <div class="relative h-fit overflow-hidden">
          {tile.imageSrc ? (
            <img
              src={tile.imageSrc}
              alt={tile.imageAlt}
              width={800}
              height={520}
              loading="lazy"
              decoding="async"
              class="h-auto w-full object-cover"
            />
          ) : (
            <div class="flex min-h-52 items-center justify-center px-4 text-sm text-foreground-muted">
              Image coming soon
            </div>
          )}
        </div>
        <div class="flex flex-col gap-2 p-4 xl:p-8">
          <div class="flex flex-col gap-0">
            <p class="text-xs font-medium uppercase tracking-[0.14em] text-foreground-muted">
              {tile.eyebrow}
            </p>
            <h3 class="text-lg font-semibold tracking-[-0.03em]">
              {tile.title}
            </h3>
          </div>
          <p class="flex-1 text-sm leading-relaxed text-foreground-muted">
            {tile.summary}
          </p>
        </div>
      </a>
    ))
  }
</div>

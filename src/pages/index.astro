---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { posts, services, site } from '../data/hvac-site-data';
---

<Layout
  title={`${site.name} | Cleveland HVAC repair, install & maintenance`}
  description={`${site.tagline} Call ${site.phoneDisplay} for service, tune-ups, and emergency help.`}
  currentPath="/"
>
  <main>
    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto grid w-[90%] max-w-none grid-cols-12 gap-8 py-16 md:gap-12 md:py-24">
        <div class="col-span-12 lg:col-span-7">
          <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">Greater Cleveland HVAC</p>
          <h1 class="mt-4 text-[clamp(2.25rem,5vw,4rem)] font-semibold leading-[0.98] tracking-[-0.045em]">
            Heating and cooling you can schedule without the runaround.
          </h1>
          <p class="mt-6 max-w-prose text-base leading-relaxed text-foreground-muted">
            From Lakewood to Parma and across the Heights, we handle repairs, replacements, and tune-ups for homes and
            light commercial spaces. Straight answers, clear scope, and a crew that shows up when we say we will.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <button
              type="button"
              class="inline-flex min-h-11 cursor-pointer items-center justify-center rounded-full bg-inverse px-6 text-[0.95rem] font-medium text-inverse-foreground"
              data-drawer-open
            >
              Request service
            </button>
            <a
              href={`tel:${site.phoneTel}`}
              class="text-sm font-medium text-foreground no-underline hover:underline"
            >
              {site.phoneDisplay}
            </a>
          </div>
        </div>
        <div class="col-span-12 flex flex-col justify-end gap-6 border-t border-border pt-8 text-sm text-foreground-muted lg:col-span-5 lg:border-l lg:border-t-0 lg:pl-10 lg:pt-0">
          <div>
            <p class="text-[11px] font-medium uppercase tracking-[0.14em]">Service area</p>
            <p class="mt-2 leading-relaxed">
              {site.serviceArea.slice(0, 5).join(' · ')}
              <span class="text-foreground-muted"> and nearby communities.</span>
            </p>
          </div>
          <div>
            <p class="text-[11px] font-medium uppercase tracking-[0.14em]">Emergencies</p>
            <p class="mt-2 leading-relaxed">
              No heat in January or a dead AC during a July stretch—call and we’ll prioritize the dispatch queue.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="w-full border-b border-border bg-background" aria-label="Trust">
      <div class="mx-auto w-[90%] max-w-none py-6 md:py-8">
        <p class="text-center text-sm text-foreground-muted md:text-left">
          Licensed and insured · Written estimates for replacements · Maintenance plans available
        </p>
      </div>
    </section>

    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto grid w-[90%] max-w-none grid-cols-12 gap-8 py-16 md:gap-10 md:py-20">
        <div class="col-span-12 flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div>
            <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">Services</p>
            <h2 class="mt-2 text-[clamp(1.5rem,2.5vw,2.25rem)] font-semibold leading-tight tracking-[-0.04em]">
              What we work on every week
            </h2>
          </div>
          <a
            href="/services"
            class="inline-flex min-h-10 w-fit items-center justify-center rounded-full border border-border bg-transparent px-4 text-sm font-medium text-foreground no-underline hover:bg-surface-muted"
          >
            All services
          </a>
        </div>
        <div class="col-span-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5">
          {services.map((service) => (
            <a
              href={`/services#${service.slug}`}
              class="flex flex-col rounded-2xl border border-border bg-surface p-5 no-underline text-current shadow-[0_1px_0_rgba(0,0,0,0.03)] transition-colors hover:bg-surface-muted md:p-6"
            >
              <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">Service</p>
              <h3 class="mt-3 text-lg font-semibold tracking-[-0.03em]">{service.name}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-foreground-muted">{service.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="w-full border-b border-border bg-surface/50">
      <div class="mx-auto grid w-[90%] max-w-none grid-cols-12 gap-8 py-16 md:gap-10 md:py-20">
        <div class="col-span-12 md:col-span-5">
          <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">From the blog</p>
          <h2 class="mt-2 text-[clamp(1.5rem,2.5vw,2rem)] font-semibold leading-tight tracking-[-0.04em]">
            Straight answers on equipment and seasons in Northeast Ohio
          </h2>
        </div>
        <div class="col-span-12 md:col-span-7">
          <ul class="grid gap-6">
            {posts.slice(0, 2).map((post) => (
              <li class="border-b border-border pb-6 last:border-b-0 last:pb-0">
                <a href={`/blog/${post.slug}`} class="group block no-underline">
                  <span class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">
                    {post.category}
                  </span>
                  <span class="mt-2 block text-lg font-semibold tracking-[-0.03em] text-foreground group-hover:underline">
                    {post.title}
                  </span>
                  <span class="mt-2 block text-sm leading-relaxed text-foreground-muted">{post.excerpt}</span>
                </a>
              </li>
            ))}
          </ul>
          <a
            href="/blog"
            class="mt-8 inline-flex text-sm font-medium text-foreground no-underline hover:underline"
          >
            View all articles →
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

---
import '../styles/global.css';
import ContactDrawer from '../components/ContactDrawer.astro';
import { nav, site } from '../data/hvac-site-data';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'North Coast Heating & Cooling | Cleveland HVAC',
  description = 'Heating, air conditioning, and indoor comfort for homes and businesses across Greater Cleveland.',
  currentPath = '/',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="m-0 min-h-screen bg-background font-sans text-foreground antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="sticky top-6 z-40 w-full">
        <div class="mx-auto flex w-[90%] max-w-none justify-center">
          <nav
            class="inline-flex items-center gap-2 rounded-full border border-border bg-surface p-1.5 shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] backdrop-blur-sm"
            aria-label="Primary"
          >
            <a
              href="/"
              class="inline-flex h-11 w-28 items-center justify-center rounded-full border border-border bg-surface-muted text-sm font-medium text-foreground no-underline"
            >
              {site.logoInitials}
            </a>
            <div class="h-8 w-px bg-border" aria-hidden="true"></div>
            <div class="flex items-center gap-1 sm:gap-1.5">
              {nav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'inline-flex min-h-10 items-center rounded-full px-3.5 text-sm text-foreground no-underline transition-colors',
                    currentPath === item.href
                      ? 'border border-border bg-surface-muted'
                      : 'border border-transparent bg-transparent hover:bg-surface-muted/60',
                  ]}
                >
                  {item.label}
                </a>
              ))}
              <div class="ml-1 h-8 w-px bg-border" aria-hidden="true"></div>
              <button
                type="button"
                class="inline-flex h-11 min-w-28 cursor-pointer items-center justify-center rounded-full border border-transparent bg-inverse px-4 text-[0.95rem] font-medium text-inverse-foreground"
                data-drawer-open
              >
                Contact
              </button>
            </div>
          </nav>
        </div>
      </header>

      <slot />

      <footer class="mt-auto w-full border-t border-border bg-background">
        <div class="mx-auto grid w-[90%] max-w-none grid-cols-12 gap-6 py-10 md:gap-8 md:py-12">
          <div class="col-span-12 md:col-span-7">
            <p class="text-xs font-medium uppercase tracking-[0.14em] text-foreground-muted">{site.name}</p>
            <p class="mt-2 max-w-prose text-sm leading-relaxed text-foreground-muted">
              Licensed HVAC for Greater Cleveland—repairs, replacements, maintenance, and light commercial service.
            </p>
          </div>
          <div class="col-span-12 flex flex-col gap-2 text-sm text-foreground-muted md:col-span-3">
            <a href={`tel:${site.phoneTel}`} class="text-foreground no-underline hover:underline">{site.phoneDisplay}</a>
            <span>{site.city}</span>
          </div>
          <div class="col-span-12 md:col-span-2 md:flex md:items-start md:justify-end">
            <button
              type="button"
              class="inline-flex h-fit w-full cursor-pointer items-center justify-center rounded-full bg-inverse px-4 py-2.5 text-[0.95rem] font-medium text-inverse-foreground md:w-auto"
              data-drawer-open
            >
              Contact
            </button>
          </div>
          <div class="col-span-12 border-t border-border pt-6 text-xs text-foreground-muted">
            Serving {site.serviceArea.slice(0, 6).join(' · ')}
            {site.serviceArea.length > 6 ? ' · …' : ''}
          </div>
        </div>
      </footer>
    </div>

    <ContactDrawer />
  </body>
</html>

---
import ContactDrawer from './ContactDrawer.astro';
import { nav, site } from '../data/site';

const { title, description, currentPath = '/' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen">
      <header class="sticky top-6 z-40 mx-auto w-full max-w-[1280px] px-4 md:px-6">
        <div class="flex justify-center">
          <nav class="inline-flex items-center gap-2 rounded-full border border-[#cfcfcf] bg-[#ececec] p-1.5 shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] backdrop-blur">
            <a href="/" class="inline-flex h-11 w-28 items-center justify-center rounded-full border border-[#cfcfcf] bg-[#e1e1e1] text-sm font-medium text-[#141414] no-underline">
              NW
            </a>

            <div class="h-8 w-px bg-[#cfcfcf]"></div>

            <div class="flex items-center gap-1 sm:gap-1.5">
              {nav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'inline-flex min-h-10 items-center rounded-full px-3.5 text-sm text-[#141414] no-underline transition-colors',
                    currentPath === item.href ? 'border border-[#cfcfcf] bg-[#e1e1e1]' : 'border border-transparent bg-transparent',
                  ]}
                >
                  {item.label}
                </a>
              ))}

              <div class="ml-1 h-8 w-px bg-[#cfcfcf]"></div>

              <button type="button" class="inline-flex h-11 w-28 items-center justify-center rounded-full border border-transparent bg-[#3a3a3a] px-4 text-[0.95rem] font-medium text-[#fafafa]" data-drawer-open>
                Contact us
              </button>
            </div>
          </nav>
        </div>
      </header>

      <slot />

      <footer class="mx-auto w-full max-w-[1280px] px-4 pb-6 md:px-6 md:pb-8">
        <div class="rounded-[24px] border border-[#cfcfcf] bg-[#ececec] p-5 shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] md:p-6">
          <div class="grid gap-4 md:grid-cols-[1fr_auto_auto] md:items-end">
            <div class="grid gap-2">
              <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b]">Footer module</div>
              <div class="text-xl font-medium tracking-[-0.03em]">Minimal HVAC website theme.</div>
              <p class="max-w-[68ch] text-base leading-[1.55] text-[#5b5b5b]">Built to be reskinned per brand without changing the core layout logic.</p>
            </div>
            <div class="text-sm text-neutral-700">Service area: {site.serviceArea.join(' • ')}</div>
            <button type="button" class="inline-flex min-h-11 items-center justify-center rounded-full bg-[#3a3a3a] px-4 text-[0.95rem] font-medium text-[#fafafa]" data-drawer-open>Open contact drawer</button>
          </div>
        </div>
      </footer>
    </div>

    <ContactDrawer />
  </body>
</html>

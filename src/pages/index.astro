---
export const prerender = false;

import Button from '../components/Button.astro';
import BlogTeaserSection from '../components/BlogTeaserSection.astro';
import BucketGrid from '../components/BucketGrid.astro';
import Layout from '../layouts/Layout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import Slideshow from '../components/Slideshow.astro';
import {
  heroSpecialSlides,
  posts as fallbackPosts,
  services,
  site,
} from '../data/hvac-site-data';
import { getEmDashEntry } from 'emdash';
import { asRecord } from '../lib/emdash/asRecord';
import { loadContentTiles } from '../lib/emdash/loadContentTiles';
import { loadHomePostTeasers } from '../lib/emdash/loadHomePosts';
import { loadSlideshow } from '../lib/emdash/loadSlideshow';
import { mapTileData } from '../lib/emdash/mapTile';
import type { ContentTileProps } from '../lib/emdash/mapTile';
import type { HomePostTeaser } from '../lib/emdash/loadHomePosts';

const slideshowSlug = 'home-featured';

const cmsSlideshow = await loadSlideshow(slideshowSlug);
const fallbackSlides = heroSpecialSlides.map((s) => ({
  segment: s.segment,
  title: s.title,
  blurb: s.blurb,
  ctaLabel: s.ctaLabel,
  ctaHref: s.ctaHref,
  imageSrc: s.imageSrc,
  imageAlt: s.imageAlt,
}));

const slides = cmsSlideshow?.slides?.length ? cmsSlideshow.slides : fallbackSlides;
const titleHeadingLevel = cmsSlideshow?.titleHeadingLevel ?? 'h1';

let tilesSectionEyebrow = 'Services';
let tilesSectionHeading = 'How we help our customers';
let blogTeaserEyebrow = 'From the blog';
let blogTeaserHeading =
  'Straight answers on equipment and seasons in Northeast Ohio';

const { entry: homePage } = await getEmDashEntry('pages', 'home');
if (homePage) {
  const h = asRecord(homePage.data);
  if (typeof h.tiles_section_eyebrow === 'string') tilesSectionEyebrow = h.tiles_section_eyebrow;
  if (typeof h.tiles_section_heading === 'string') tilesSectionHeading = h.tiles_section_heading;
  if (typeof h.blog_teaser_eyebrow === 'string') blogTeaserEyebrow = h.blog_teaser_eyebrow;
  if (typeof h.blog_teaser_heading === 'string') blogTeaserHeading = h.blog_teaser_heading;
}

let tiles: ContentTileProps[] = await loadContentTiles('home');
if (tiles.length === 0) {
  tiles = services.map((s) =>
    mapTileData({
      eyebrow: 'Service',
      title: s.name,
      summary: s.summary,
      link_href: `/services#${s.slug}`,
      sort_order: 0,
      placement: 'both',
    }),
  );
}

let postTeasers: HomePostTeaser[] = await loadHomePostTeasers(2);
if (postTeasers.length === 0) {
  postTeasers = fallbackPosts.slice(0, 2).map((p) => ({
    slug: p.slug,
    title: p.title,
    excerpt: p.excerpt,
    category: p.category,
  }));
}
---

<Layout
  title={`${site.name} | Cleveland HVAC repair, install & maintenance`}
  description={`${site.tagline} Call ${site.phoneDisplay} for service, tune-ups, and emergency help.`}
  currentPath="/"
>
  <main>
    <Slideshow
      slides={slides}
      titleHeadingLevel={titleHeadingLevel}
      rootId="slideshow"
      ariaLabel="Featured HVAC offers and service highlights"
    />

    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto grid p-16 max-w-none grid-cols-12 gap-8">
        <SectionIntro eyebrow={tilesSectionEyebrow} heading={tilesSectionHeading}>
          <div slot="actions" class="flex w-full justify-start md:justify-end">
            <Button href="/services" class="w-fit">All services</Button>
          </div>
        </SectionIntro>
        <BucketGrid tiles={tiles} />
      </div>
    </section>

    <BlogTeaserSection
      eyebrow={blogTeaserEyebrow}
      heading={blogTeaserHeading}
      posts={postTeasers}
    />
  </main>
</Layout>

---
export const prerender = true;

import Button from '../components/Button.astro';
import SubpageHero from '../components/SubpageHero.astro';
import Layout from '../layouts/Layout.astro';
import { heroSpecialSlides, site } from '../data/hvac-site-data';
---

<Layout
  title={`About | ${site.name}`}
  description={`Local HVAC team serving ${site.city} and surrounding suburbs. Repairs, installs, and maintenance with clear communication.`}
  currentPath="/about"
>
  <main>
    <SubpageHero
      eyebrow="About"
      title="Built for repeat service—not one-call churn"
      description={`${site.name} focuses on diagnostics you can follow, timelines that respect your schedule, and equipment choices matched to your house—not a generic package. We carry liability coverage and pull permits when code requires it, and we document model and serial numbers so warranty and future service stay simple.`}
      imageSrc={heroSpecialSlides[0].imageSrc}
      imageAlt={heroSpecialSlides[0].imageAlt}
    />

    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto max-w-none p-8">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-border bg-surface p-4">
            <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">How we work</p>
            <p class="mt-3 text-sm leading-relaxed text-foreground-muted">
              Dispatch confirms the window. Technicians call if traffic shifts it. After the visit you get findings,
              options, and pricing before we move ahead on non-emergency work.
            </p>
          </div>
          <div class="rounded-2xl border border-border bg-surface p-4">
            <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">Who we serve</p>
            <p class="mt-3 text-sm leading-relaxed text-foreground-muted">
              Single-family and multifamily residential, plus small retail and office HVAC where downtime matters.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="w-full bg-background">
      <div class="mx-auto max-w-none p-8">
        <p class="max-w-prose text-base leading-relaxed text-foreground-muted">
          Questions about rebates, filter sizes, or whether to repair versus replace? Use the contact drawer—we would
          rather steer you right than sell you something you do not need.
        </p>
        <Button type="button" class="mt-8" data-drawer-open>
          Contact us
        </Button>
      </div>
    </section>
  </main>
</Layout>

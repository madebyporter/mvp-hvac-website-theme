---
export const prerender = true;

import Button from "../components/Button.astro";
import Layout from "../layouts/Layout.astro";
import {
  heroSpecialSlides,
  posts,
  services,
  site,
} from "../data/hvac-site-data";
---

<Layout
  title={`${site.name} | Cleveland HVAC repair, install & maintenance`}
  description={`${site.tagline} Call ${site.phoneDisplay} for service, tune-ups, and emergency help.`}
  currentPath="/"
>
  <main>
    <section
      id="hero"
      class="w-full border-b border-border bg-background"
      aria-roledescription="carousel"
      aria-label="Featured HVAC offers and service highlights"
    >
      <div class="mx-auto p-2 max-w-none">
        <div
          class="grid grid-cols-1 overflow-hidden rounded-2xl border border-border bg-zinc-950 ring-1 ring-black/5 md:grid-cols-12 md:rounded-none md:border-0 md:ring-0 lg:rounded-sm"
        >
          <div
            class="relative flex min-h-[min(58vh,560px)] flex-col md:order-1 md:col-span-5 md:min-h-[min(72vh,640px)]"
          >
            <div class="relative flex min-h-0 flex-1 flex-col">
              {
                heroSpecialSlides.map((slide, i) => (
                  <div
                    data-hero-slide-panel={i}
                    hidden={i !== 0}
                    aria-hidden={i === 0 ? "false" : "true"}
                    class="flex flex-1 flex-col justify-end p-16"
                  >
                    <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-white/55">
                      {slide.segment}
                    </p>
                    <h1 class="mt-3 text-[clamp(1.5rem,3.5vw,2.75rem)] font-semibold leading-[1.05] tracking-[-0.03em] text-white text-pretty">
                      {slide.title}
                    </h1>
                    <p class="mt-4 max-w-md text-sm leading-relaxed text-white/75">
                      {slide.blurb}
                    </p>
                    <a
                      href={slide.ctaHref}
                      class="mt-6 inline-flex w-fit items-center gap-1 text-sm font-medium text-white underline decoration-white/35 underline-offset-4 transition-colors hover:decoration-white"
                    >
                      {slide.ctaLabel}
                      <span aria-hidden="true">→</span>
                    </a>
                  </div>
                ))
              }
            </div>
            <div
              class="flex shrink-0 items-center justify-between p-8"
            >
              <div
                class="flex items-center gap-2"
                role="group"
                aria-label="Slide indicators"
              >
                {
                  heroSpecialSlides.map((_, i) => (
                    <Button
                      variant="dash"
                      type="button"
                      data-hero-slide-dot={i}
                      aria-label={`Slide ${i + 1} of ${heroSpecialSlides.length}`}
                      aria-current={i === 0 ? "true" : undefined}
                      class:list={[i === 0 ? "bg-white" : "bg-white/30"]}
                    />
                  ))
                }
              </div>
              <div class="flex gap-1">
                <Button
                  variant="icon"
                  type="button"
                  data-hero-slide-prev
                  class="text-lg"
                  aria-label="Previous slide"
                >
                  ‹
                </Button>
                <Button
                  variant="icon"
                  type="button"
                  data-hero-slide-next
                  class="text-lg"
                  aria-label="Next slide"
                >
                  ›
                </Button>
              </div>
            </div>
            
          </div>
          <div
            class="relative order-first min-h-[min(36vh,280px)] md:order-2 md:col-span-7 md:min-h-[min(72vh,640px)]"
          >
            {
              heroSpecialSlides.map((slide, i) => (
                <img
                  data-hero-slide-img={i}
                  src={slide.imageSrc}
                  alt={slide.imageAlt}
                  width={1600}
                  height={1067}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                  aria-hidden={i === 0 ? "false" : "true"}
                  class:list={[
                    "absolute inset-0 h-full w-full object-cover transition-opacity duration-500 motion-reduce:transition-none",
                    i === 0 ? "opacity-100" : "opacity-0",
                  ]}
                />
              ))
            }
          </div>
        </div>
      </div>
      <script is:inline src="/hero-specials.js"></script>
    </section>

    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto grid p-16 max-w-none grid-cols-12 gap-8">
        <div
          class="col-span-12 flex flex-col justify-between gap-6 md:flex-row md:items-end"
        >
          <div>
            <p
              class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted"
            >
              Services
            </p>
            <h2
              class="mt-2 text-[clamp(1.5rem,2.5vw,2.25rem)] font-semibold leading-tight tracking-[-0.04em]"
            >
              How we help our customers
            </h2>
          </div>
          <Button href="/services" class="w-fit">
            All services
          </Button>
        </div>
        <div
          class="col-span-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-5"
        >
          {
            services.map((service) => (
              <a
                href={`/services#${service.slug}`}
                class="flex flex-col rounded-2xl border border-border bg-surface p-5 no-underline text-current shadow-[0_1px_0_rgba(0,0,0,0.03)] transition-colors hover:bg-surface-muted md:p-6"
              >
                <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">
                  Service
                </p>
                <h3 class="mt-3 text-lg font-semibold tracking-[-0.03em]">
                  {service.name}
                </h3>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-foreground-muted">
                  {service.summary}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="w-full border-b border-border bg-surface/50">
      <div class="mx-auto grid p-16 max-w-none grid-cols-12 gap-8">
        <div class="col-span-12 md:col-span-5">
          <p
            class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted"
          >
            From the blog
          </p>
          <h2
            class="mt-2 text-[clamp(1.5rem,2.5vw,2rem)] font-semibold leading-tight tracking-[-0.04em]"
          >
            Straight answers on equipment and seasons in Northeast Ohio
          </h2>
        </div>
        <div class="col-span-12 md:col-span-7">
          <ul class="grid gap-6">
            {
              posts.slice(0, 2).map((post) => (
                <li class="border-b border-border pb-6 last:border-b-0 last:pb-0">
                  <a
                    href={`/blog/${post.slug}`}
                    class="group block no-underline"
                  >
                    <span class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">
                      {post.category}
                    </span>
                    <span class="mt-2 block text-lg font-semibold tracking-[-0.03em] text-foreground group-hover:underline">
                      {post.title}
                    </span>
                    <span class="mt-2 block text-sm leading-relaxed text-foreground-muted">
                      {post.excerpt}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
          <a
            href="/blog"
            class="mt-8 inline-flex text-sm font-medium text-foreground no-underline hover:underline"
          >
            View all articles →
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

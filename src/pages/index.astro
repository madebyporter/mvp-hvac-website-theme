---
import Layout from '../layouts/Layout.astro';
import SiteFrame from '../components/SiteFrame.astro';
import { services, posts, site } from '../data/site';

const proofModules = [
  { label: 'Response window', value: 'Same day', note: 'Clear service framing without hero clutter' },
  { label: 'Review signal', value: '4.9 ★', note: 'Trust presented like a spec, not a badge pile' },
  { label: 'Membership base', value: '1,200+', note: 'Retention/repeat revenue module' },
  { label: 'Coverage', value: '24/7', note: 'Emergency service layer' },
];
---

<Layout title="HVAC Theme / Home" description="Minimal HVAC website wireframe homepage.">
  <SiteFrame title="HVAC Theme / Home" description="Minimal HVAC website wireframe homepage." currentPath="/">
    <main class="bg-[#f5f5f5] min-h-screen py-6 md:py-8">
      <div class="section-shell grid gap-4 md:gap-6">
        <section class="grid gap-4 md:grid-cols-[1.25fr_.75fr]">
          <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[28px] p-5 md:p-8">
            <div class="grid gap-8">
              <div class="grid gap-3">
                <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b]">Minimal HVAC theme / SEO + GEO friendly</div>
                <h1 class="text-[clamp(2.75rem,6vw,6.5rem)] leading-[0.94] tracking-[-0.055em] font-semibold max-w-[11ch]">Calmer structure. Better trust. Easier action.</h1>
                <p class="max-w-[68ch] text-base leading-[1.55] text-[#5b5b5b]">A cleaner HVAC homepage system designed to feel more like a modern product site than a cluttered local-service ad page. Blocky modules, strong hierarchy, easy brand swapping, and obvious conversion paths.</p>
              </div>

              <div class="grid gap-3 md:grid-cols-[1fr_auto] md:items-end">
                <div class="grid gap-3 md:grid-cols-3">
                  <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-2xl p-4">
                    <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Primary CTA</div>
                    <div class="text-sm text-neutral-700">Bottom drawer starts with agentic chat, then classic form as fallback.</div>
                  </div>
                  <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-2xl p-4">
                    <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">SEO structure</div>
                    <div class="text-sm text-neutral-700">Built for services, local pages, and blog content architecture.</div>
                  </div>
                  <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-2xl p-4">
                    <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Brand system</div>
                    <div class="text-sm text-neutral-700">Neutral grayscale base now. Brand accent drops in later.</div>
                  </div>
                </div>
                <button type="button" class="inline-flex min-h-11 cursor-pointer items-center justify-center gap-2 rounded-full border border-transparent bg-[#3a3a3a] px-4 text-[0.95rem] font-medium text-[#fafafa] no-underline" data-drawer-open>Open contact drawer</button>
              </div>
            </div>
          </div>

          <aside class="grid gap-4">
            <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-[28px] p-5 md:p-6">
              <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Utility rail</div>
              <div class="grid gap-3">
                <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-2xl p-4">{site.phone}</div>
                <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-2xl p-4">Serving {site.serviceArea.slice(0, 3).join(' / ')}</div>
                <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#c9c9c9] rounded-2xl p-4 text-sm font-medium text-white">Emergency repair available</div>
              </div>
            </div>
            <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[28px] p-5 md:p-6">
              <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Visual notes</div>
              <div class="grid gap-2 text-sm text-neutral-700">
                <p>4px spacing system.</p>
                <p>Inter / Helvetica feel.</p>
                <p>Blocky editorial modules.</p>
                <p>Minimal for HVAC, not generic startup.</p>
              </div>
            </div>
          </aside>
        </section>

        <section class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[24px] p-5 md:p-8">
          <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
            <div class="grid gap-2">
              <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b]">Services</div>
              <h2 class="text-[clamp(1.5rem,2vw,2.5rem)] leading-[0.98] tracking-[-0.045em] font-semibold">Core service modules.</h2>
            </div>
            <a href="/services" class="inline-flex min-h-11 items-center justify-center rounded-full border border-[#cfcfcf] bg-transparent px-4 text-[0.95rem] font-medium text-[#141414] no-underline">See all services</a>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            {services.map((service) => (
              <a href="/services" class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-[22px] p-5 no-underline text-current transition hover:translate-y-[-1px]">
                <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-3">Service module</div>
                <h3 class="text-2xl font-medium tracking-[-0.04em]">{service.name}</h3>
                <p class="mt-3 text-sm leading-6 text-neutral-700">{service.summary}</p>
              </a>
            ))}
          </div>
        </section>

        <section class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-[24px] p-5 md:p-8">
          <div class="mb-5 grid gap-2">
            <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b]">Trust / proof</div>
            <h2 class="text-[clamp(1.5rem,2vw,2.5rem)] leading-[0.98] tracking-[-0.045em] font-semibold">Trust shown as structure, not noise.</h2>
          </div>
          <div class="grid gap-4 md:grid-cols-4">
            {proofModules.map((item) => (
              <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-2xl p-4 md:p-5">
                <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-6">{item.label}</div>
                <div class="text-3xl font-semibold tracking-[-0.04em]">{item.value}</div>
                <div class="mt-2 text-sm text-neutral-700">{item.note}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="grid gap-4 md:grid-cols-[1fr_1fr]">
          <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[24px] p-5 md:p-8">
            <div class="mb-4 grid gap-2">
              <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b]">About module</div>
              <h2 class="text-[clamp(1.5rem,2vw,2.5rem)] leading-[0.98] tracking-[-0.045em] font-semibold">Designed to feel modern without looking fake.</h2>
            </div>
            <p class="max-w-[68ch] text-base leading-[1.55] text-[#5b5b5b]">The goal is not “tech startup HVAC.” The goal is a calmer, more disciplined local-service website with better spacing, less clutter, and clearer action paths.</p>
            <a href="/about" class="mt-5 inline-flex min-h-11 items-center justify-center rounded-full border border-[#cfcfcf] bg-transparent px-4 text-[0.95rem] font-medium text-[#141414] no-underline">About the company</a>
          </div>

          <div class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#ececec] rounded-[24px] p-5 md:p-8">
            <div class="mb-4 grid gap-2">
              <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b]">Blog / GEO</div>
              <h2 class="text-[clamp(1.5rem,2vw,2.5rem)] leading-[0.98] tracking-[-0.045em] font-semibold">Content patterns for search capture.</h2>
            </div>
            <div class="grid gap-3">
              {posts.slice(0, 2).map((post) => (
                <a href={`/blog/${post.slug}`} class="border border-[#cfcfcf] rounded-[12px] shadow-[0_1px_0_rgba(0,0,0,0.03),0_0_0_1px_rgba(0,0,0,0.03)] bg-[#e1e1e1] rounded-2xl p-4 no-underline text-current">
                  <div class="text-[11px] leading-none tracking-[0.14em] uppercase text-[#5b5b5b] mb-2">{post.category}</div>
                  <div class="text-lg font-medium tracking-[-0.03em]">{post.title}</div>
                </a>
              ))}
            </div>
          </div>
        </section>
      </div>
    </main>
  </SiteFrame>
</Layout>

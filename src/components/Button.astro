---
import type { HTMLAttributes } from "astro/types";

/**
 * Primary actions match the header Contact control: inverse fill, rounded-xs, h-11.
 * Pass `href` to render a styled link (same look as the default button).
 */
type Common = {
  variant?: "primary" | "icon" | "dash" | "tab";
  class?: string;
};

type Props =
  | (Common &
      Omit<HTMLAttributes<"button">, "class" | "type"> & {
        href?: undefined;
        type?: "button" | "submit" | "reset";
      })
  | (Common &
      Omit<HTMLAttributes<"a">, "class" | "href"> & {
        href: string;
      });

const raw = Astro.props as Props;
const {
  variant = "primary",
  class: className = "",
  href,
  type = "button",
  ...rest
} = raw as Common & Record<string, unknown> & { href?: string; type?: string };

const primary =
  "inline-flex h-11 min-w-28 cursor-pointer items-center justify-center rounded-xs border border-transparent bg-inverse px-4 text-[0.95rem] font-medium text-inverse-foreground";

const icon =
  "inline-flex h-11 w-11 min-w-0 shrink-0 cursor-pointer items-center justify-center rounded-xs border border-transparent bg-inverse text-[0.95rem] font-medium text-inverse-foreground";

const dash =
  "h-0.5 w-8 min-h-0 min-w-8 cursor-pointer rounded-full border-0 p-0 transition-colors duration-300";

/** Selection state follows `aria-selected` (updated by contact-drawer.js). */
const tab =
  "inline-flex min-h-10 min-w-0 cursor-pointer items-center justify-center rounded-xs border border-transparent bg-inverse px-4 text-sm font-medium text-inverse-foreground aria-[selected=true]:ring-2 aria-[selected=true]:ring-white/60 aria-[selected=false]:opacity-55 aria-[selected=false]:hover:opacity-100";

let variantClass = primary;
if (variant === "icon") variantClass = icon;
else if (variant === "dash") variantClass = dash;
else if (variant === "tab") variantClass = tab;
---

{
  href ? (
    <a
      href={href}
      class:list={[variantClass, className, "no-underline"]}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type as "button" | "submit" | "reset"}
      class:list={[variantClass, className]}
      {...rest}
    >
      <slot />
    </button>
  )
}

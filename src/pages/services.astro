---
export const prerender = false;

import BucketGrid from '../components/BucketGrid.astro';
import Button from '../components/Button.astro';
import SubpageHero from '../components/SubpageHero.astro';
import Layout from '../layouts/Layout.astro';
import { heroSpecialSlides, services, site } from '../data/hvac-site-data';
import { loadContentTiles } from '../lib/emdash/loadContentTiles';
import { mapTileData } from '../lib/emdash/mapTile';
import type { ContentTileProps } from '../lib/emdash/mapTile';

let tiles: ContentTileProps[] = await loadContentTiles('services');
if (tiles.length === 0) {
  tiles = services.map((s) =>
    mapTileData({
      eyebrow: 'Service',
      title: s.name,
      summary: s.summary,
      link_href: `/services#${s.slug}`,
      image_src: s.imageSrc,
      image_alt: s.imageAlt,
      sort_order: 0,
      placement: 'both',
    }),
  );
}
---

<Layout
  title={`HVAC services | ${site.name}`}
  description="Air conditioning, heating, maintenance, and commercial HVAC for Cleveland and western suburbs. Repairs, replacements, and tune-ups."
  currentPath="/services"
>
  <main>
    <SubpageHero
      eyebrow="Services"
      title="HVAC for homes and businesses west of the Cuyahoga"
      description="Whether you need a same-day refrigerant leak found or a furnace swap before the lake-effect cold sets in, we structure visits so you know what failed, what it costs, and what happens next."
      imageSrc={heroSpecialSlides[1].imageSrc}
      imageAlt={heroSpecialSlides[1].imageAlt}
    >
      <div slot="actions" class="pt-2">
        <Button type="button" class="w-full md:w-auto" data-drawer-open>
          Book or ask a question
        </Button>
      </div>
    </SubpageHero>

    <section class="w-full border-b border-border bg-background">
      <div class="mx-auto grid max-w-none grid-cols-12 gap-8 p-8 md:p-16">
        <BucketGrid tiles={tiles} />
      </div>
    </section>

    <section class="w-full bg-background">
      <div class="mx-auto max-w-none divide-y divide-border p-8">
        {services.map((service) => (
          <article id={service.slug} class="grid grid-cols-12 gap-6 p-8 md:gap-10">
            <div class="col-span-12 md:col-span-5">
              <h2 class="text-2xl font-semibold tracking-[-0.035em] md:text-3xl">{service.name}</h2>
            </div>
            <div class="col-span-12 md:col-span-7">
              <p class="text-base leading-relaxed text-foreground-muted">{service.summary}</p>
              <ul class="mt-6 grid gap-2 text-sm text-foreground-muted">
                <li class="flex gap-2">
                  <span class="text-foreground" aria-hidden="true">—</span>
                  Upfront scope: diagnosis first, then options—not a laundry list of upsells.
                </li>
                <li class="flex gap-2">
                  <span class="text-foreground" aria-hidden="true">—</span>
                  Parts common to Cleveland installs stocked on trucks when possible.
                </li>
                <li class="flex gap-2">
                  <span class="text-foreground" aria-hidden="true">—</span>
                  Paper trail: model/serial photos and filter size on the invoice when relevant.
                </li>
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

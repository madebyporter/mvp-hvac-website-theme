---
---

<div
  id="contact-drawer"
  class="group fixed inset-0 z-50 transition-opacity duration-200 aria-[hidden=true]:pointer-events-none aria-[hidden=true]:opacity-0 aria-[hidden=false]:opacity-100"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-drawer-title"
>
  <div class="absolute inset-0 bg-[rgba(12,12,12,0.24)]" data-drawer-close tabindex="-1"></div>
  <div
    class="absolute bottom-4 left-4 right-4 max-h-[calc(100vh-2rem)] translate-y-6 overflow-y-auto rounded-[28px] border border-border bg-surface p-5 shadow-[0_1px_0_rgba(0,0,0,0.03)] transition-transform duration-200 group-aria-[hidden=false]:translate-y-0 md:bottom-6 md:left-6 md:right-6 md:p-6"
  >
    <div class="mx-auto mb-4 h-1 w-12 rounded-full bg-surface-strong" aria-hidden="true"></div>
    <div class="flex items-start justify-between gap-4">
      <div class="grid gap-2">
        <p class="text-[11px] font-medium uppercase leading-none tracking-[0.14em] text-foreground-muted">Contact</p>
        <h2 id="contact-drawer-title" class="text-[clamp(1.35rem,2vw,2rem)] font-semibold leading-[1.05] tracking-[-0.04em]">
          Schedule service or ask a question
        </h2>
        <p class="max-w-[60ch] text-sm leading-relaxed text-foreground-muted">
          Use chat when your AI agent is connected, or send a message with the form—we respond during business hours and
          prioritize no-heat and no-AC emergencies.
        </p>
      </div>
      <button
        type="button"
        class="flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-full border border-border bg-surface-muted text-2xl leading-none text-foreground"
        data-drawer-close
        aria-label="Close"
      >
        ×
      </button>
    </div>

    <div
      class="mt-6 inline-flex rounded-full border border-border bg-surface-muted p-1 text-sm"
      role="tablist"
      aria-label="Contact method"
    >
      <button
        type="button"
        role="tab"
        id="tab-chat"
        aria-selected="true"
        aria-controls="panel-chat"
        class="cursor-pointer rounded-full px-4 py-2 font-medium transition-colors aria-[selected=true]:bg-inverse aria-[selected=true]:text-inverse-foreground aria-[selected=false]:bg-transparent aria-[selected=false]:text-foreground"
        data-tab-target="chat"
      >
        Chat
      </button>
      <button
        type="button"
        role="tab"
        id="tab-form"
        aria-selected="false"
        aria-controls="panel-form"
        class="cursor-pointer rounded-full px-4 py-2 font-medium transition-colors aria-[selected=true]:bg-inverse aria-[selected=true]:text-inverse-foreground aria-[selected=false]:bg-transparent aria-[selected=false]:text-foreground"
        data-tab-target="form"
      >
        Form
      </button>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-12 md:gap-6">
      <section
        id="panel-chat"
        role="tabpanel"
        aria-labelledby="tab-chat"
        class="rounded-2xl border border-border bg-surface-muted p-4 md:col-span-7 md:p-5"
        data-tab-panel="chat"
      >
        <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">Assistant</p>
        <p class="mt-4 text-sm leading-relaxed text-foreground-muted">
          Connect your agent endpoint here (widget, iframe, or SDK). This area stays minimal so the live experience stays
          on-brand.
        </p>
        <div
          class="mt-6 flex min-h-[120px] items-center justify-center rounded-xl border border-dashed border-border bg-background/80 px-4 text-center text-sm text-foreground-muted"
        >
          AI chat surface (placeholder)
        </div>
      </section>

      <section
        id="panel-form"
        role="tabpanel"
        aria-labelledby="tab-form"
        hidden
        class="rounded-2xl border border-border bg-surface-muted p-4 md:col-span-5 md:p-5"
        data-tab-panel="form"
      >
        <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-foreground-muted">Message</p>
        <form class="mt-4 grid gap-3" method="post" action="#" data-contact-form>
          <label class="grid gap-1 text-sm font-medium text-foreground">
            Name
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-12 w-full rounded-2xl border border-border bg-surface px-4 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-2 focus:ring-inverse/20"
              placeholder="Your name"
            />
          </label>
          <label class="grid gap-1 text-sm font-medium text-foreground">
            Email
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-12 w-full rounded-2xl border border-border bg-surface px-4 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-2 focus:ring-inverse/20"
              placeholder="you@example.com"
            />
          </label>
          <label class="grid gap-1 text-sm font-medium text-foreground">
            Phone
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              class="min-h-12 w-full rounded-2xl border border-border bg-surface px-4 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-2 focus:ring-inverse/20"
              placeholder="(216) …"
            />
          </label>
          <label class="grid gap-1 text-sm font-medium text-foreground">
            Zip or city
            <input
              type="text"
              name="location"
              autocomplete="address-level2"
              class="min-h-12 w-full rounded-2xl border border-border bg-surface px-4 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-2 focus:ring-inverse/20"
              placeholder="44102 or Lakewood"
            />
          </label>
          <label class="grid gap-1 text-sm font-medium text-foreground">
            What do you need?
            <select
              name="service"
              class="min-h-12 w-full rounded-2xl border border-border bg-surface px-4 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-inverse/20"
            >
              <option value="">Select…</option>
              <option value="ac">Air conditioning</option>
              <option value="heat">Heating</option>
              <option value="maintenance">Maintenance / tune-up</option>
              <option value="commercial">Commercial</option>
              <option value="other">Other</option>
            </select>
          </label>
          <label class="grid gap-1 text-sm font-medium text-foreground">
            Details
            <textarea
              name="message"
              rows="3"
              class="w-full resize-y rounded-2xl border border-border bg-surface px-4 py-3 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-2 focus:ring-inverse/20"
              placeholder="Equipment age, symptoms, best time to call…"
            ></textarea>
          </label>
          <button
            type="submit"
            class="inline-flex min-h-11 w-full cursor-pointer items-center justify-center rounded-full bg-inverse px-4 text-[0.95rem] font-medium text-inverse-foreground"
          >
            Send message
          </button>
          <p class="text-xs text-foreground-muted">
            Wire this form to your endpoint (e.g. Netlify Forms, server action, or CRM). <code class="rounded bg-surface px-1 py-0.5 text-[11px]">action</code> is a placeholder.
          </p>
        </form>
      </section>
    </div>
  </div>
</div>

<script is:inline src="/contact-drawer.js"></script>
